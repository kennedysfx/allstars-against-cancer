generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Donor {
  id        String     @id @default(uuid())
  email     String     @unique
  name      String?
  donations Donation[]
}

model Donation {
  id            String   @id @default(uuid())
  amount        Float
  paymentMethod String   // e.g., "GOOGLE_PAY", "PAYPAL", "CRYPTO", "CARD"
  date          DateTime @default(now())
  donorId       String
  donor         Donor    @relation(fields: [donorId], references: [id])
}

model Subscriber {
  id        String   @id @default(uuid())
  email     String   @unique
  firstName String
  lastName  String
  createdAt DateTime @default(now())
}
